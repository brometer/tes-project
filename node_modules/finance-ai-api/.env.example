# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration (matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/finance_ai

# Better Auth Configuration
BETTER_AUTH_SECRET=changethis_secret_key_12345
